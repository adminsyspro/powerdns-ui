# PowerDNS Center Configuration

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Authentication Secret (generate with: openssl rand -base64 32)
AUTH_SECRET=your-secret-key-change-in-production

# PowerDNS Server
PDNS_API_URL=http://localhost:8081
PDNS_API_KEY=your-secret-api-key

# LDAP Authentication
LDAP_ENABLED=false
LDAP_URL=ldap://ldap.example.com:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=your-ldap-password
LDAP_USER_FILTER=(uid={{username}})
LDAP_GROUP_FILTER=(memberUid={{username}})
LDAP_USERNAME_ATTR=uid
LDAP_EMAIL_ATTR=mail
LDAP_FIRSTNAME_ATTR=givenName
LDAP_LASTNAME_ATTR=sn
LDAP_GROUP_ATTR=cn
LDAP_ADMIN_GROUP=pdns-admins
LDAP_OPERATOR_GROUP=pdns-operators

# For Active Directory, use these settings:
# LDAP_URL=ldap://ad.example.com:389
# LDAP_USER_FILTER=(sAMAccountName={{username}})
# LDAP_USERNAME_ATTR=sAMAccountName
